FLASK_ENV=development
SECRET_KEY=replace-with-a-long-random-secret-key-for-local-dev
JWT_SECRET_KEY=replace-with-a-long-random-jwt-secret-for-local-dev
FRONTEND_ORIGIN=http://localhost:3000,http://localhost:5000
USE_SQLITE=true
SQLITE_PATH=voicemart.db
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/voicemart
BCRYPT_LOG_ROUNDS=12
LOW_STOCK_SCAN_INTERVAL_MINUTES=30
SCHEDULER_TIMEZONE=UTC
PUBLIC_APP_URL=http://localhost:3000
EMAIL_NOTIFICATIONS_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=VoiceMart
EMAIL_SEND_TIMEOUT=15
REGISTRATION_OTP_EXPIRY_MINUTES=10
REGISTRATION_OTP_MAX_ATTEMPTS=5
PORT=5001
